# ========================================
# CORE APPLICATION SETTINGS
# ========================================

# Application
APP_NAME=Evols
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
API_V1_PREFIX=/api/v1

# ========================================
# DATABASE & INFRASTRUCTURE
# ========================================

# Database Configuration
# Note: For async connections, the system automatically converts to postgresql+asyncpg://
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/evols
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://localhost:6379/0

# Celery Configuration (Background Tasks)
# Set to False for local development without Redis/Celery infrastructure
# Set to True for production with durable, restartable background tasks
USE_CELERY=True

# LLM Response Caching (uses Redis)
# Set to False to disable caching for testing or to always get fresh LLM responses
LLM_CACHE_ENABLED=True

# ========================================
# SECURITY & AUTHENTICATION
# ========================================

# JWT Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# Field-level Encryption for API Keys (BYOK - Bring Your Own Keys)
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
FIELD_ENCRYPTION_KEY=

# Master encryption secret for additional encryption needs
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
ENCRYPTION_MASTER_SECRET=

# SUPER_ADMIN Creation Token (for first-time admin setup)
# Generate a secure random token: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# This token is required to create the first SUPER_ADMIN user
SUPER_ADMIN_CREATION_TOKEN=

# CORS Configuration
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
FRONTEND_URL=http://localhost:3000

# OIDC Provider (Evols AI Workbench / LibreChat SSO)
# OIDC_ISSUER — canonical issuer URL, e.g. https://evols-backend-xxx.run.app/api/v1/oidc
# OIDC_CLIENT_ID — must match OPENID_CLIENT_ID in LibreChat .env (default: evols-workbench)
# OIDC_CLIENT_SECRET — long random secret shared between backend and LibreChat
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
OIDC_ISSUER=
OIDC_CLIENT_ID=evols-workbench
OIDC_CLIENT_SECRET=

# ========================================
# LLM & AI SERVICES
# ========================================

# LLM Configuration
# NOTE: LLM API keys (OpenAI, Claude, etc.) are NOT stored in environment variables.
# Each tenant configures their own API keys via Settings → LLM Settings in the UI.
# Keys are encrypted and stored in the database per tenant (BYOK - Bring Your Own Keys).

# AWS Configuration (for Bedrock and other AWS services)
AWS_REGION=us-east-1

# Embedding Service Configuration
EMBEDDING_PROVIDER=aws_bedrock
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Internet Search API Keys (for web search tools)
# Get Tavily API key from https://tavily.com (1000 free searches/month)
TAVILY_API_KEY=

# Get Serper API key from https://serper.dev (2500 free searches/month)
SERPER_API_KEY=

# Unified PM OS Path (for framework skills)
# Path to unified-pm-os repository relative to backend directory
UNIFIED_PM_OS_PATH=../../unified-pm-os

# ========================================
# KNOWLEDGE GRAPH (LightRAG)
# ========================================

# LightRAG service URL (internal Docker network in dev, internal Cloud Run URL in prod)
LIGHTRAG_URL=http://lightrag:9621

# Shared secret between LightRAG and Evols backend.
# LightRAG sends this as X-Evols-Service-Key; the backend validates it and
# routes extraction/embedding calls through the org's BYOK LLM keys — no separate
# LLM API key needed here.
# Also set as AUTH_ACCOUNTS in the LightRAG container env.
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
LIGHTRAG_API_KEY=

# LLM model LightRAG uses for entity extraction (routed via Evols LLM proxy)
LIGHTRAG_LLM_MODEL=claude-haiku-4-5-20251001

# Embedding model LightRAG uses (routed via Evols LLM proxy)
# For Bedrock tenants use: amazon.titan-embed-text-v2:0
# For OpenAI tenants use: text-embedding-3-small
LIGHTRAG_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# ========================================
# EMAIL & NOTIFICATIONS
# ========================================

# Email Configuration (for notifications and invites)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@evols.ai

# ========================================
# FILE UPLOAD & CONTENT
# ========================================

# File Upload Limits
MAX_UPLOAD_SIZE_MB=100
ALLOWED_UPLOAD_EXTENSIONS=.csv,.xlsx,.json

# ========================================
# FEATURE FLAGS
# ========================================

# Enable/disable specific features
ENABLE_PERSONA_TWINS=True
ENABLE_DECISION_BRIEFS=True
ENABLE_KNOWLEDGE_GRAPH_VIZ=True

# ========================================
# ANALYTICS & MONITORING
# ========================================

# External Analytics Services (optional)
SENTRY_DSN=
POSTHOG_API_KEY=

# ========================================
# NOTES
# ========================================

# Internet Search:
# - Works without API keys but with degraded functionality
# - Tavily is recommended for AI-optimized search results
# - Serper provides fallback when Tavily quota is exceeded

# Encryption:
# - FIELD_ENCRYPTION_KEY is for tenant API key encryption in database
# - ENCRYPTION_MASTER_SECRET is for additional encryption needs

# Unified PM OS:
# - Provides 83 expert-curated PM framework skills
# - Default path assumes unified-pm-os is a sibling directory to evols
