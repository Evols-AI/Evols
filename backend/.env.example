# Database Configuration
# Note: For async connections, the system automatically converts to postgresql+asyncpg://
# For sync connections (like create_tables.py), postgresql:// works fine with psycopg3
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/productos
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://localhost:6379/0

# Celery Configuration (Background Tasks)
# Set to False for local development without Redis/Celery infrastructure
# Set to True for production with durable, restartable background tasks
USE_CELERY=True

# JWT Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# Field-level Encryption for API Keys (BYOK - Bring Your Own Keys)
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
FIELD_ENCRYPTION_KEY=

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Application Settings
APP_NAME=ProductOS
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# LLM Configuration (User can override these with their own keys)
# OpenAI
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# Anthropic
ANTHROPIC_API_KEY=

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@productos.ai

# File Upload
MAX_UPLOAD_SIZE_MB=100
ALLOWED_UPLOAD_EXTENSIONS=.csv,.xlsx,.json

# Feature Flags
ENABLE_PERSONA_TWINS=True
ENABLE_DECISION_BRIEFS=True
ENABLE_KNOWLEDGE_GRAPH_VIZ=True

# Analytics & Monitoring
SENTRY_DSN=
POSTHOG_API_KEY=
