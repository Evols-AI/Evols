# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Local dev only: point workbench iframe directly at LibreChat (no nginx needed)
# Leave empty in production — nginx proxy handles routing automatically
NEXT_PUBLIC_LIBRECHAT_URL=http://localhost:3080
NEXT_PUBLIC_APP_NAME=Evols
NEXT_PUBLIC_APP_VERSION=1.0.0

# Amplitude Analytics (FREE: 10M events/month + 10K session replays)
# Get your API key from: https://amplitude.com (Sign up → Create Project → Copy API Key)
NEXT_PUBLIC_AMPLITUDE_API_KEY=your_amplitude_api_key_here
