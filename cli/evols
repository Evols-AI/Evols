def cmd_login(args):
    print("Evols Login")
    print("-" * 40)
    existing = load_config() or {}
    api_key = input("Evols API Key (evols_...): ").strip() or existing.get("api_key", "")
    if not api_key:
        print("Error: API key is required.")
        sys.exit(1)
    print("  Verifying key...", end=" ", flush=True)
    plan_type = fetch_plan_type(EVOLS_API_URL_DEFAULT, api_key)
    print(f"✓  (plan: {plan_type})")
    cfg = {"api_url": EVOLS_API_URL_DEFAULT, "api_key": api_key, "plan_type": plan_type}
    save_config(cfg)
    print(f"\n✓ Logged in.")

    # Propagate new key to all already-installed agent configs
    agents = detect_agents()
    updated = []

    updaters = {
        "claude":      lambda: install_claude_mcp(cfg),
        "cursor":      lambda: install_cursor_mcp(cfg),
        "zed":         lambda: install_zed_mcp(cfg),
        "codex":       lambda: install_codex_mcp(cfg),
        "windsurf":    lambda: install_windsurf_mcp(cfg),
        "antigravity": lambda: install_antigravity_mcp(cfg),
    }

    for name, info in agents.items():
        path = info.get("settings")
        if path is None:
            continue
        # Only update if evols is already installed for this agent
        try:
            if path.suffix == ".toml":
                already = "[mcp_servers.evols]" in path.read_text()
            else:
                content = json.loads(path.read_text()) if path.exists() else {}
                already = (
                    "evols" in content.get("mcpServers", {}) or
                    "evols" in content.get("context_servers", {})
                )
        except Exception:
            already = False

        if already and name in updaters:
            try:
                updaters[name]()
                updated.append(name)
            except Exception as e:
                print(f"  ✗ {name}: failed to update — {e}")

    if updated:
        print(f"  Updated API key in: {', '.join(updated)}")
        print("  Restart your coding agents to pick up the new key.")
    else:
        print("  Run `evols install` to wire up your coding agents.")


def cmd_install(args):
    """Install global MCP server and hooks into all detected coding agents."""
    cfg = load_config()
    if not cfg:
        print("Error: not logged in. Run `evols login` first.")
        sys.exit(1)

    # Install/update CLI binary and hook scripts
    install_cli_binary()
    install_hooks()

    agents = detect_agents()
    if not agents:
        print("No coding agents detected. Checked: Claude Code, Cursor, Zed, Codex, Windsurf, Antigravity, Cline.")
        sys.exit(1)

    print(f"\nDetected agents: {', '.join(agents.keys())}")
    print("Installing Evols MCP server...\n")

    installers = {
        "claude":      lambda: (install_claude_mcp(cfg), install_claude_hooks(cfg)),
        "cursor":      lambda: (install_cursor_mcp(cfg), install_cursor_hooks(cfg)),
        "zed":         lambda: install_zed_mcp(cfg),
        "codex":       lambda: (install_codex_mcp(cfg), install_codex_hooks(cfg)),
        "windsurf":    lambda: install_windsurf_mcp(cfg),
        "antigravity": lambda: (install_antigravity_mcp(cfg), install_antigravity_hooks(cfg)),
    }

    for name in agents:
        if name in installers:
            try:
                installers[name]()
            except Exception as e:
                print(f"  ✗ {name}: failed — {e}")

    print("\n✓ Installation complete. Restart your coding agents to pick up the MCP server.")
    print("  Run `evols init` in any project to inject team context.")


def _write_context_file(path: Path, content: str, label: str):
    """Write content to path, merging if an Evols block already exists."""
    marker = "# Evols Team Intelligence"
    if path.exists():
        existing = path.read_text()
        if marker in existing:
            lines = existing.split("\n")
            start = next((i for i, l in enumerate(lines) if marker in l), None)
            if start is not None:
                end = next((i for i, l in enumerate(lines) if i > start and l.startswith("# ")), len(lines))
                existing = "\n".join(lines[:start] + lines[end:]).strip() + "\n\n"
            path.write_text(existing + content)
        else:
            path.write_text(existing.rstrip() + "\n\n" + content)
        print(f"  ✓ {label} updated")
    else:
        path.write_text(content)
        print(f"  ✓ {label} written")


def cmd_init(args):
    """Write agent context files and settings into a project directory."""
    project_dir = Path(args[0]).resolve() if args else Path.cwd()
    cfg = load_config()
    if not cfg:
        print("Error: not logged in. Run `evols login` first.")
        sys.exit(1)
    if not project_dir.exists():
        print(f"Error: directory not found: {project_dir}")
        sys.exit(1)

    print(f"Initializing Evols in {project_dir}...")
    print("  Fetching team context...")
    product_name, team_context = fetch_tier1_context(cfg)
    new_block = generate_claude_md(cfg, product_name, team_context)

    detected = detect_agents()

    # CLAUDE.md — always (Claude Code reads it; also a safe fallback)
    _write_context_file(project_dir / "CLAUDE.md", new_block, "CLAUDE.md")

    # AGENTS.md — always (Codex; also a safe cross-agent fallback)
    _write_context_file(project_dir / "AGENTS.md", new_block, "AGENTS.md")

    # .cursorrules — only if Cursor is installed
    if "cursor" in detected:
        _write_context_file(project_dir / ".cursorrules", new_block, ".cursorrules")

    # .windsurfrules — only if Windsurf is installed
    if "windsurf" in detected:
        _write_context_file(project_dir / ".windsurfrules", new_block, ".windsurfrules")

    # .clinerules — only if Cline VSCode extension is installed
    if "cline" in detected:
        _write_context_file(project_dir / ".clinerules", new_block, ".clinerules")

    # .antigravityrules — only if Antigravity is installed
    if "antigravity" in detected:
        _write_context_file(project_dir / ".antigravityrules", new_block, ".antigravityrules")

    print(f"\n✓ Project initialized. Restart your coding agent to pick up changes.")


def cmd_status(args):
    cfg = load_config()
    agents = detect_agents()

    print("Evols Status")
    print("=" * 40)
    print(f"Config:     {'✓ ' + str(CONFIG_FILE) if cfg else '✗ not found — run evols login'}")
    print(f"CLI:        ✓ {CLI_PATH}")
    print(f"Hooks:      {'✓ ' + str(HOOKS_DIR) if HOOKS_DIR.exists() else '✗ not found — run evols install'}")
    print()
    print("Detected agents:")
    for name, info in agents.items():
        path = info.get("settings")
        if path is None:
            # Agent detected but config is managed via project .mcp.json (e.g. Cline)
            print(f"  {name:14} ✓ detected")
            continue
        try:
            if not path.exists():
                has_evols = False
            elif path.suffix == ".toml":
                has_evols = "[mcp_servers.evols]" in path.read_text()
            else:
                content = json.loads(path.read_text())
                has_evols = (
                    "evols" in content.get("mcpServers", {}) or
                    "evols" in content.get("context_servers", {})
                )
            status = "✓ MCP installed" if has_evols else "✗ not installed — run evols install"
        except Exception:
            status = "? (could not read config)"
        print(f"  {name:14} {status}")

    claude_settings = Path.home() / ".claude" / "settings.json"
    if claude_settings.exists():
        try:
            s = json.loads(claude_settings.read_text())
            hook_names = list(s.get("hooks", {}).keys())
            print(f"\nClaude Code hooks: {', '.join(hook_names) if hook_names else 'none'}")
        except Exception:
            pass

    # Cline detection for status display
    detected = detect_agents()

    cwd = Path.cwd()
    print(f"\nCurrent project ({cwd.name}):")
    context_files = [
        ("CLAUDE.md",      cwd / "CLAUDE.md"),
        ("AGENTS.md",      cwd / "AGENTS.md"),
        (".cursorrules",   cwd / ".cursorrules"),
        (".windsurfrules", cwd / ".windsurfrules"),
        (".clinerules",    cwd / ".clinerules"),
        (".antigravityrules", cwd / ".antigravityrules"),
    ]
    for label, path in context_files:
        if path.exists():
            print(f"  {label:28} ✓")
    if not any(p.exists() for _, p in context_files):
        print(f"  (none) — run evols init")


