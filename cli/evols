        "cline":       lambda: install_cline_mcp(cfg),
        "copilot":     lambda: install_copilot_mcp(cfg),
    }

    for name, info in agents.items():
        path = info.get("settings")
        if path is None:
            continue
        # Only update if evols is already installed for this agent
        try:
            if path.suffix == ".toml":
                already = "[mcp_servers.evols]" in path.read_text()
            else:
                content = json.loads(path.read_text()) if path.exists() else {}
                already = (
                    "evols" in content.get("mcpServers", {}) or
