# ── Agent detection ────────────────────────────────────────────────────────────

def _vscode_extensions_dirs() -> list:
    """Return candidate VSCode/Cursor extensions directories that exist."""
    candidates = [
        Path.home() / ".vscode" / "extensions",
        Path.home() / ".cursor" / "extensions",
        # Linux VSCode snap
        Path.home() / "snap" / "code" / "current" / ".vscode" / "extensions",
    ]
    return [p for p in candidates if p.exists()]

def _cline_mcp_settings_path() -> Optional[Path]:
    """Return the path to Cline's global MCP settings file (first found)."""
    candidates = [
        # VSCode on macOS
        Path.home() / "Library" / "Application Support" / "Code" / "User" / "globalStorage" / "saoudrizwan.claude-dev" / "settings" / "cline_mcp_settings.json",
        # Cursor on macOS
        Path.home() / "Library" / "Application Support" / "Cursor" / "User" / "globalStorage" / "saoudrizwan.claude-dev" / "settings" / "cline_mcp_settings.json",
        # Linux VSCode
        Path.home() / ".config" / "Code" / "User" / "globalStorage" / "saoudrizwan.claude-dev" / "settings" / "cline_mcp_settings.json",
    ]
    for p in candidates:
        if p.parent.exists():
            return p
    # Fall back to the first candidate (will be created)
    return candidates[0] if candidates else None


def _copilot_mcp_settings_path() -> Optional[Path]:
    """Return path to GitHub Copilot's MCP config in VSCode user settings."""
    candidates = [
        # macOS
        Path.home() / "Library" / "Application Support" / "Code" / "User" / "settings.json",
        # Linux
        Path.home() / ".config" / "Code" / "User" / "settings.json",
    ]
    for p in candidates:
        if p.exists():
            return p
    return candidates[0] if candidates else None


def detect_agents() -> dict:
    agents = {}
    if (Path.home() / ".claude").exists():
        agents["claude"] = {"settings": Path.home() / ".claude" / "settings.json", "type": "claude"}
    if (Path.home() / ".cursor").exists():
        agents["cursor"] = {"settings": Path.home() / ".cursor" / "mcp.json", "type": "cursor"}
    if (Path.home() / ".config" / "zed").exists():
        agents["zed"] = {"settings": Path.home() / ".config" / "zed" / "settings.json", "type": "zed"}
    if (Path.home() / ".codex").exists():
        agents["codex"] = {"settings": Path.home() / ".codex" / "config.toml", "type": "codex"}
    if (Path.home() / ".codeium" / "windsurf").exists():
        agents["windsurf"] = {"settings": Path.home() / ".codeium" / "windsurf" / "mcp_config.json", "type": "windsurf"}
    if (Path.home() / ".gemini" / "antigravity").exists():
        agents["antigravity"] = {"settings": Path.home() / ".gemini" / "antigravity" / "mcp_config.json", "type": "antigravity"}
    # Cline: VSCode extension saoudrizwan.claude-dev
    for ext_dir in _vscode_extensions_dirs():
        if any(p.name.startswith("saoudrizwan.claude-dev") for p in ext_dir.iterdir() if p.is_dir()):
            cline_settings = _cline_mcp_settings_path()
            agents["cline"] = {"settings": cline_settings, "type": "cline"}
            break
    # GitHub Copilot: detect via VSCode extension github.copilot-chat
    for ext_dir in _vscode_extensions_dirs():
        if any(p.name.startswith("github.copilot-chat") for p in ext_dir.iterdir() if p.is_dir()):
            agents["copilot"] = {"settings": _copilot_mcp_settings_path(), "type": "copilot"}
            break
    return agents


# ── Config helpers ─────────────────────────────────────────────────────────────

def load_config() -> dict | None:
    if not CONFIG_FILE.exists():
        return None
    try:
        return json.loads(CONFIG_FILE.read_text())
    except Exception:
        return None


def save_config(cfg: dict):
    EVOLS_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2) + "\n")


