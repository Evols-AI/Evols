#!/usr/bin/env python3
"""
Evols CLI
Commands:
  evols login               — save API credentials
  evols install             — install global MCP server + hooks into all detected agents
  evols init [path]         — inject team context into a project for all detected agents
  evols status              — show what's installed and configured
  evols mcp-server          — run the MCP stdio server (spawned automatically by agents)
"""

import sys
import json
import shutil
import urllib.request
import urllib.parse
from pathlib import Path

EVOLS_DIR = Path.home() / ".evols"
CONFIG_FILE = EVOLS_DIR / "config.json"
HOOKS_DIR = EVOLS_DIR / "hooks"
BIN_DIR = EVOLS_DIR / "bin"
CLI_PATH = Path(__file__).resolve()

EVOLS_API_URL_DEFAULT = "https://api.evols.ai"


# ── Agent detection ────────────────────────────────────────────────────────────

def _vscode_extensions_dirs() -> list:
    """Return candidate VSCode/Cursor extensions directories that exist."""
    candidates = [
        Path.home() / ".vscode" / "extensions",
        Path.home() / ".cursor" / "extensions",
        # Linux VSCode snap
        Path.home() / "snap" / "code" / "current" / ".vscode" / "extensions",
    ]
    return [p for p in candidates if p.exists()]

def detect_agents() -> dict:
    agents = {}
    if (Path.home() / ".claude").exists():
        agents["claude"] = {"settings": Path.home() / ".claude" / "settings.json", "type": "claude"}
    if (Path.home() / ".cursor").exists():
        agents["cursor"] = {"settings": Path.home() / ".cursor" / "mcp.json", "type": "cursor"}
    if (Path.home() / ".config" / "zed").exists():
        agents["zed"] = {"settings": Path.home() / ".config" / "zed" / "settings.json", "type": "zed"}
    if (Path.home() / ".codex").exists():
        agents["codex"] = {"settings": Path.home() / ".codex" / "config.toml", "type": "codex"}
    if (Path.home() / ".codeium" / "windsurf").exists():
        agents["windsurf"] = {"settings": Path.home() / ".codeium" / "windsurf" / "mcp_config.json", "type": "windsurf"}
    if (Path.home() / ".gemini" / "antigravity").exists():
        agents["antigravity"] = {"settings": Path.home() / ".gemini" / "antigravity" / "mcp_config.json", "type": "antigravity"}
    # Cline: VSCode extension saoudrizwan.claude-dev
    for ext_dir in _vscode_extensions_dirs():
        if any(p.name.startswith("saoudrizwan.claude-dev") for p in ext_dir.iterdir() if p.is_dir()):
            agents["cline"] = {"type": "cline"}
            break
    return agents


# ── Config helpers ─────────────────────────────────────────────────────────────

def load_config() -> dict | None:
    if not CONFIG_FILE.exists():
        return None
    try:
        return json.loads(CONFIG_FILE.read_text())
    except Exception:
        return None


def save_config(cfg: dict):
    EVOLS_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2) + "\n")


# ── MCP entry builder — points to `evols mcp-server` ─────────────────────────

