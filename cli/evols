    ("claude",       _claude_discover,       _claude_extract,       CLAUDE_PROJECTS_DIR.is_dir if CLAUDE_PROJECTS_DIR.exists() else lambda: False),
    ("codex",        _codex_discover,        _codex_extract,        lambda: CODEX_SESSIONS_DIR.is_dir() or CODEX_SESSION_INDEX.exists()),
    ("antigravity",  _antigravity_discover,  _antigravity_extract,  lambda: ANTIGRAVITY_SESSIONS_DIR.is_dir()),
    ("cline",        _cline_discover,        _cline_extract,        lambda: bool(_cline_task_dirs())),
