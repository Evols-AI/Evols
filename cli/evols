COMMANDS = {
    "login":      cmd_login,
    "install":    cmd_install,
    "init":       cmd_init,
    "status":     cmd_status,
    "mcp-server": cmd_mcp_server,
}

USAGE = """Usage: evols <command> [args]

Commands:
  login           Save Evols API credentials
  install         Install MCP server + hooks into all detected coding agents
  init [path]     Inject team context into a project for all detected agents
  status          Show installation status
  mcp-server      Run MCP stdio server (spawned automatically by agents)

Examples:
  evols login
  evols install
  evols init
  evols status
"""


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(USAGE)
        sys.exit(0)
    command = sys.argv[1]
    if command not in COMMANDS:
        print(f"Unknown command: {command}\n{USAGE}")
        sys.exit(1)
    COMMANDS[command](sys.argv[2:])


if __name__ == "__main__":
    main()
