            continue
        cwd = _claude_slug_to_path(project_dir.name)
        for jsonl in project_dir.glob("*.jsonl"):
            try:
                stat = jsonl.stat()
            except OSError:
                continue
            yield SessionRef(
                agent="claude",
                source_id=jsonl.stem,
                source_path=str(jsonl),
                source_mtime=int(stat.st_mtime),
                source_size=stat.st_size,
                cwd=cwd,
            )


def _claude_extract(ref: SessionRef) -> Optional[ExtractedSession]:
    path = Path(ref.source_path)
    if not path.exists():
        return None
    text_lines, files_read, files_modified = [], set(), set()
    per_message: dict = {}
    no_id_totals = {"input_tokens": 0, "output_tokens": 0,
                    "cache_creation_input_tokens": 0, "cache_read_input_tokens": 0}
    model = ""
    started_at = ended_at = None
    try:
        with open(path, encoding="utf-8", errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except Exception:
                    continue
                ts = entry.get("timestamp") or entry.get("ts")
                if ts:
                    started_at = started_at or ts
                    ended_at = ts
                msg = entry.get("message", {})
                role = msg.get("role", "")
                content = msg.get("content", "")
                usage = msg.get("usage", {})
                if usage:
                    m = msg.get("model", "")
                    if m:
                        model = m
                    mid = msg.get("id")
                    if mid:
                        per_message[mid] = usage
                    else:
                        for k in no_id_totals:
                            no_id_totals[k] += usage.get(k, 0)
                if role == "user" and isinstance(content, str) and content.strip():
                    text_lines.append(f"User: {content[:600]}")
                elif role == "assistant":
                    if isinstance(content, str) and content.strip():
                        text_lines.append(f"Assistant: {content[:800]}")
                    elif isinstance(content, list):
                        for block in content:
                            if not isinstance(block, dict):
                                continue
                            btype = block.get("type")
                            if btype == "text":
                                text_lines.append(f"Assistant: {block.get('text','')[:800]}")
                            elif btype == "tool_use":
                                name = block.get("name")
                                inp = block.get("input", {})
                                text_lines.append(f"Tool: {name}({json.dumps(inp)[:300]})")
                                fpath = inp.get("file_path") or inp.get("filePath") or inp.get("path")
                                if fpath:
                                    if name in ("Read", "Glob", "Grep"):
                                        files_read.add(fpath)
                                    elif name in ("Edit", "Write", "MultiEdit", "NotebookEdit"):
                                        files_modified.add(fpath)
    except Exception:
        return None
    if not text_lines:
        return None
    totals = dict(no_id_totals)
    for u in per_message.values():
        for k in totals:
            totals[k] += u.get(k, 0)
    tokens_used = (totals["input_tokens"] + totals["output_tokens"] +
                   totals["cache_creation_input_tokens"]) or None
    return ExtractedSession(
        agent="claude",
        source_session_id=ref.source_id,
        transcript_text="\n".join(text_lines[-120:]),
        started_at=started_at, ended_at=ended_at, cwd=ref.cwd,
        model=model or None, tokens_used=tokens_used,
        files_read=sorted(files_read), files_modified=sorted(files_modified),
        schema_version="claude:1",
    )


def _codex_find_file(session_id: str) -> Optional[Path]:
    if not CODEX_SESSIONS_DIR.is_dir():
        return None
    matches = list(CODEX_SESSIONS_DIR.rglob(f"rollout-*-{session_id}.jsonl"))
    return matches[0] if matches else None


def _codex_discover() -> Iterable[SessionRef]:
    if not (CODEX_SESSIONS_DIR.is_dir() or CODEX_SESSION_INDEX.exists()):
        return
    seen: set = set()
    if CODEX_SESSION_INDEX.exists():
        try:
            with open(CODEX_SESSION_INDEX, encoding="utf-8") as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        entry = json.loads(line)
                    except Exception:
                        continue
                    sid = entry.get("id")
                    if not sid or sid in seen:
                        continue
                    seen.add(sid)
                    path = _codex_find_file(sid)
                    if not path:
                        continue
                    try:
                        stat = path.stat()
                    except OSError:
                        continue
                    yield SessionRef(
                        agent="codex", source_id=sid, source_path=str(path),
                        source_mtime=int(stat.st_mtime), source_size=stat.st_size,
                    )
        except Exception:
            pass
    if CODEX_SESSIONS_DIR.is_dir():
        for path in CODEX_SESSIONS_DIR.rglob("rollout-*.jsonl"):
            try:
                parts = path.stem.split("-")
                sid = "-".join(parts[-5:]) if len(parts) >= 5 else None
                if not sid or sid in seen:
                    continue
                stat = path.stat()
                seen.add(sid)
                yield SessionRef(
                    agent="codex", source_id=sid, source_path=str(path),
                    source_mtime=int(stat.st_mtime), source_size=stat.st_size,
                )
            except OSError:
                continue


def _codex_extract(ref: SessionRef) -> Optional[ExtractedSession]:
    path = Path(ref.source_path)
    if not path.exists():
        return None
    text_lines, files_read, files_modified = [], set(), set()
    cwd = model = started_at = ended_at = None
    try:
        with open(path, encoding="utf-8", errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    rec = json.loads(line)
                except Exception:
                    continue
                ts = rec.get("timestamp")
                if ts:
                    started_at = started_at or ts
                    ended_at = ts
                rtype = rec.get("type")
                payload = rec.get("payload", {}) or {}
                if rtype == "session_meta":
                    cwd = payload.get("cwd") or cwd
                    model = payload.get("model") or model
                elif rtype == "turn_context":
                    model = payload.get("model") or model
                elif rtype == "response_item":
                    ptype = payload.get("type")
                    if ptype == "message":
                        role = payload.get("role", "")
                        content = payload.get("content") or []
                        pieces = []
                        if isinstance(content, list):
                            for block in content:
                                if isinstance(block, dict) and block.get("type") in ("input_text", "output_text", "text"):
                                    t = block.get("text") or ""
                                    if t:
                                        pieces.append(t)
                        elif isinstance(content, str):
                            pieces.append(content)
                        txt = " ".join(pieces).strip()
                        if txt:
                            prefix = "User" if role == "user" else ("Assistant" if role == "assistant" else None)
                            if prefix:
                                text_lines.append(f"{prefix}: {txt[:800]}")
                    elif ptype == "function_call":
                        name = payload.get("name", "")
                        args_raw = payload.get("arguments") or ""
                        try:
                            args = json.loads(args_raw) if args_raw else {}
                        except Exception:
                            args = {}
                        text_lines.append(f"Tool: {name}({json.dumps(args)[:300]})")
    except Exception:
        return None
    if not text_lines:
        return None
    return ExtractedSession(
        agent="codex",
        source_session_id=ref.source_id,
        transcript_text="\n".join(text_lines[-150:]),
        started_at=started_at, ended_at=ended_at, cwd=cwd,
        model=model, tokens_used=None,
        files_read=sorted(files_read), files_modified=sorted(files_modified),
        schema_version="codex:1",
    )


