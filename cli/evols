def install_cli_binary():
    """Copy this script to ~/.evols/bin/evols and ensure /opt/homebrew/bin symlink exists.
    Only runs when invoked from the repo layout (i.e. CLI_PATH != BIN_DIR/evols).
    """
    dest = BIN_DIR / "evols"
    if CLI_PATH == dest:
        return  # already running from installed location, nothing to do

    BIN_DIR.mkdir(parents=True, exist_ok=True)
    shutil.copy2(CLI_PATH, dest)
    dest.chmod(0o755)

    # Ensure the symlink in /opt/homebrew/bin (standard Homebrew prefix on Apple Silicon)
    homebrew_bin = Path("/opt/homebrew/bin")
    if homebrew_bin.exists():
        symlink = homebrew_bin / "evols"
        if not symlink.exists() or (symlink.is_symlink() and symlink.resolve() != dest.resolve()):
            try:
                if symlink.is_symlink() or symlink.exists():
                    symlink.unlink()
                symlink.symlink_to(dest)
            except PermissionError:
                pass  # symlink already correct or no permission — not fatal

    print(f"  ✓ CLI binary updated ({dest})")


def install_hooks():
    """Copy hook scripts to ~/.evols/hooks/.
    Source: cli/hooks/ alongside this script (repo layout),
    or ~/.evols/hooks/ if already installed (deployed layout).
    """
    HOOKS_DIR.mkdir(parents=True, exist_ok=True)

    # In repo layout: hooks/ is a sibling of this script
    # In deployed layout (~/.evols/bin/evols): hooks are already at ~/.evols/hooks/
    src_dir = CLI_PATH.parent / "hooks"
    if not src_dir.exists():
        # Already deployed — hooks should already be in HOOKS_DIR
        existing = list(HOOKS_DIR.glob("*.py"))
        if existing:
            print(f"  ✓ Hooks already installed ({len(existing)} scripts in {HOOKS_DIR})")
        else:
            print(f"  ✗ No hooks found. Re-run install from the evols repo or re-download the CLI.")
        return

    hook_files = [
        "session_start.py", "user_prompt_submit.py", "pre_tool_use.py",
        "post_tool_use.py", "pre_compact.py", "stop.py",
    ]
    copied = []
    for fname in hook_files:
        src = src_dir / fname
        if src.exists():
            shutil.copy2(src, HOOKS_DIR / fname)
            copied.append(fname)

    if copied:
        print(f"  ✓ Hooks installed: {', '.join(copied)}")
    else:
        print(f"  ✗ No hooks found in {src_dir}")


# ── CLAUDE.md template ─────────────────────────────────────────────────────────

def generate_claude_md(cfg: dict, product_name: str = "", team_context: str = "") -> str:
    product_line = f"**Product:** {product_name}\n" if product_name else ""
    context_block = f"\n{team_context}\n" if team_context else ""
    return f"""# Evols Team Intelligence

{product_line}{context_block}
## MANDATORY WORKFLOW — Follow this exactly or you will waste the user's time and tokens

**Step 0 — At the very beginning of the session:**
Call `mcp__evols__get_work_context_summary` to understand the user's current role, active projects, and priorities. This ensures you are aligned with the team's immediate focus.

**Step 1 — Before doing anything on any research, analysis, planning, or PM task:**
Call `mcp__evols__check_redundancy` with a description of what you're about to do.
- If it returns a match: you MUST immediately call `mcp__evols__get_team_context` with the same query to retrieve the full prior work. Do not generate any response until you have read that full content. Build your answer on top of what already exists — do not start from scratch.
- If it returns no match: proceed normally.

Skipping this step or ignoring a match means the user gets a generic answer when they already have specific decisions and context stored. This is the single most important rule.

**Step 2 — When you see `[Evols] A teammate already worked on something similar` in your context:**
Stop immediately. Do not proceed. Surface the existing work to the user and ask whether to reuse it or start fresh. The content in that message is a preview only — call `mcp__evols__get_team_context` to get the full stored knowledge before answering.

**Step 3 — After completing any focused unit of work** (one research topic, one component, one investigation):
Call `mcp__evols__sync_subtask_context` with your findings. This prevents teammates from repeating the same work and ensures persistence even if the session ends unexpectedly.

**Step 4 — When the user's request maps to a PM skill** (research, PRD, OKRs, outreach, event strategy, etc.):
Call `mcp__evols__get_skill_details` with the skill name before starting.

## Context

Team knowledge is automatically loaded at session start. To fetch additional context: `mcp__evols__get_work_context_summary`.

## Coding Agent Rules

- Always check logs first before guessing root cause.
- Never run `git reset --hard` with unstaged changes.
- Call `mcp__evols__get_work_context_summary` at the start of every session.
- Call `mcp__evols__check_redundancy` before starting any research task.
- After completing each focused subtask, call `mcp__evols__sync_subtask_context`.
""" + "\n"


# ── Context fetcher ────────────────────────────────────────────────────────────

def fetch_tier1_context(cfg: dict) -> tuple[str, str]:
    api_url = cfg.get("api_url", "")
    api_key = cfg.get("api_key", "")
    product_name = ""
    context_text = ""
    try:
        req = urllib.request.Request(
            f"{api_url.rstrip('/')}/api/v1/products",
            headers={"Authorization": f"Bearer {api_key}"},
        )
        with urllib.request.urlopen(req, timeout=5) as resp:
            products = json.loads(resp.read())
        if products and isinstance(products, list):
            product_name = products[0].get("name", "")
    except Exception:
        pass
    try:
        params = urllib.parse.urlencode({"query": "team context project overview", "top_k": 3})
        req = urllib.request.Request(
            f"{api_url.rstrip('/')}/api/v1/team-knowledge/relevant?{params}",
            headers={"Authorization": f"Bearer {api_key}"},
        )
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read())
        if data and data.get("entry_count", 0) > 0:
            context_text = data.get("context_text", "")[:800]
    except Exception:
        pass
    return product_name, context_text


def fetch_plan_type(api_url: str, api_key: str) -> str:
    try:
        req = urllib.request.Request(
            f"{api_url.rstrip('/')}/api/v1/auth/me",
            headers={"Authorization": f"Bearer {api_key}"},
        )
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read())
        plan = data.get("tenant", {}).get("plan") or data.get("plan") or "pro"
        return plan.lower()
    except Exception:
        return "pro"


# ── MCP stdio server ───────────────────────────────────────────────────────────

def cmd_mcp_server(args):
    """
    Run the Evols MCP stdio server.
    Spawned automatically by coding agents — users never call this directly.
    Reads JSON-RPC from stdin, proxies tool calls to the Evols backend API,
    writes responses to stdout.
    """
    import os
    import traceback

    api_url = os.environ.get("EVOLS_API_URL", EVOLS_API_URL_DEFAULT)
    api_key = os.environ.get("EVOLS_API_KEY", "")

    # Fall back to config file if env vars not set
    if not api_key:
        cfg = load_config()
        if cfg:
            api_url = cfg.get("api_url", api_url)
            api_key = cfg.get("api_key", "")

    def api_post(path: str, payload: dict) -> dict:
        data = json.dumps(payload).encode()
        req = urllib.request.Request(
            f"{api_url.rstrip('/')}{path}",
            data=data,
            headers={
                "Authorization": f"Bearer {api_key}",
                "Content-Type": "application/json",
            },
        )
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())

    def api_get(path: str) -> dict:
        req = urllib.request.Request(
            f"{api_url.rstrip('/')}{path}",
            headers={"Authorization": f"Bearer {api_key}"},
        )
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())

    def send(obj: dict):
        sys.stdout.write(json.dumps(obj) + "\n")
        sys.stdout.flush()

    def error_response(req_id, code: int, message: str) -> dict:
        return {"jsonrpc": "2.0", "id": req_id, "error": {"code": code, "message": message}}

    def handle(msg: dict) -> dict | None:
        method = msg.get("method", "")
        req_id = msg.get("id")
        params = msg.get("params", {})

        if method == "initialize":
            # Fetch server info from backend MCP endpoint
            try:
                result = api_post("/api/v1/mcp", {
                    "jsonrpc": "2.0", "id": 1, "method": "initialize", "params": params,
                })
                return {"jsonrpc": "2.0", "id": req_id, "result": result.get("result", {})}
            except Exception as e:
                return error_response(req_id, -32603, f"Backend unavailable: {e}")

        elif method == "notifications/initialized":
            return None  # no response for notifications

        elif method == "tools/list":
            try:
                result = api_post("/api/v1/mcp", {
                    "jsonrpc": "2.0", "id": 1, "method": "tools/list", "params": params,
                })
                return {"jsonrpc": "2.0", "id": req_id, "result": result.get("result", {"tools": []})}
            except Exception as e:
                return error_response(req_id, -32603, f"Backend unavailable: {e}")

        elif method == "tools/call":
            try:
                result = api_post("/api/v1/mcp", {
                    "jsonrpc": "2.0", "id": 1, "method": "tools/call", "params": params,
                })
                return {"jsonrpc": "2.0", "id": req_id, "result": result.get("result", {})}
            except Exception as e:
                return {"jsonrpc": "2.0", "id": req_id, "result": {
                    "content": [{"type": "text", "text": f"Error: {e}"}],
                    "isError": True,
                }}

        elif req_id is not None:
            return error_response(req_id, -32601, f"Method not found: {method}")

        return None

    # Main stdio loop
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
        except json.JSONDecodeError:
            send(error_response(None, -32700, "Parse error"))
            continue
        try:
            response = handle(msg)
            if response is not None:
                send(response)
        except Exception:
            send(error_response(msg.get("id"), -32603, traceback.format_exc()))


