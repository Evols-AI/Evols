]


# ── cmd_sync ───────────────────────────────────────────────────────────────────

def cmd_sync(args):
    """Backfill historical sessions from all supported agents (Claude Code, Codex, Antigravity, Cline, Copilot)."""
    dry_run = "--dry-run" in args
    agent_filter = None
    for a in args:
        if a.startswith("--agent="):
            agent_filter = a.split("=", 1)[1]

    cfg = load_config()
    if not cfg:
        print("Not logged in. Run: evols login")
        sys.exit(1)

    client = _EvolsClient(cfg["api_url"], cfg["api_key"])
    conn = _sync_open_db()

    # Seed: on first sync, pull already-uploaded entries so we don't re-ship them.
    if not SEED_DONE_MARKER.exists():
        print("First sync — seeding from backend to avoid duplicates...")
        seeded = 0
        try:
            for entry in client.iter_existing_entries():
                sid = entry.get("source_session_id")
                agent = entry.get("agent") or "unknown"
                if sid:
                    existing = _sync_get_synced(conn, agent, sid)
                    if not existing:
                        _sync_upsert(conn, agent=agent, source_id=sid,
                                     source_path=None, source_mtime=0,
                                     status="seeded",
                                     evols_entry_id=entry.get("id"))
                        seeded += 1
        except Exception as e:
            print(f"  Warning: could not seed from backend: {e}")
        SEED_DONE_MARKER.write_text(str(int(time.time())))
        print(f"  Seeded {seeded} existing entries.")

    total_seen = total_synced = total_skipped = total_failed = 0

    for agent_name, discover_fn, extract_fn, is_present_fn in _EXTRACTORS:
        if agent_filter and agent_name != agent_filter:
            continue
        if not is_present_fn():
            continue
        print(f"\nScanning {agent_name} sessions...")
        for ref in discover_fn():
            total_seen += 1
            # Skip live session
            if _is_live_session(ref.source_id):
                total_skipped += 1
                continue
            # Check local db
            row = _sync_get_synced(conn, ref.agent, ref.source_id)
            if row and row["status"] in ("synced", "seeded"):
                total_skipped += 1
                continue
            # Extract
            session = extract_fn(ref)
            if not session:
                total_skipped += 1
                continue
            if dry_run:
                print(f"  [dry-run] would sync: {ref.source_id[:16]}... ({agent_name})")
                total_synced += 1
                continue
            # Upload
            with _session_lock(ref.source_id) as lock_fd:
                if lock_fd is None:
                    total_skipped += 1
                    continue
                try:
                    entry_id, deduped = client.post_with_retry(session.to_payload())
                    status = "synced"
                    _sync_upsert(conn, agent=ref.agent, source_id=ref.source_id,
                                 source_path=ref.source_path, source_mtime=ref.source_mtime,
                                 status=status, evols_entry_id=entry_id,
                                 schema_version=session.schema_version)
                    label = "deduped" if deduped else "synced"
                    print(f"  ✓ {label}: {ref.source_id[:16]}...")
                    total_synced += 1
                except Exception as e:
                    _sync_upsert(conn, agent=ref.agent, source_id=ref.source_id,
                                 source_path=ref.source_path, source_mtime=ref.source_mtime,
                                 status="failed", last_error=str(e)[:255],
                                 attempts=(row["attempts"] + 1 if row else 1))
                    print(f"  ✗ failed: {ref.source_id[:16]}... — {e}")
                    total_failed += 1

    print(f"\nSync complete: {total_synced} synced, {total_skipped} skipped, {total_failed} failed ({total_seen} total seen)")
    conn.close()


