def install_cursor_hooks(cfg: dict):
    """Wire hooks into ~/.cursor/hooks.json using Cursor's full hook surface."""
    path = Path.home() / ".cursor" / "hooks.json"
    try:
        s = json.loads(path.read_text()) if path.exists() else {}
    except Exception:
        s = {}

    py = sys.executable
    hd = str(HOOKS_DIR)
    s.setdefault("version", 1)
    hooks = s.setdefault("hooks", {})

    # Session lifecycle
    hooks["sessionStart"]       = [{"command": f"{py} {hd}/session_start.py"}]
    # sessionEnd intentionally omitted — Cursor kills the process on window close
    # before it can complete, causing spurious "hook failed" banners. stop handles cleanup.

    # Prompt validation (redundancy check)
    hooks["beforeSubmitPrompt"] = [{"command": f"{py} {hd}/user_prompt_submit.py"}]

    # Tool use — generic pre/post (covers all tools including shell and MCP)
    hooks["preToolUse"]         = [{"command": f"{py} {hd}/pre_tool_use.py"}]
    hooks["postToolUse"]        = [{"command": f"{py} {hd}/post_tool_use.py"}]

    # Context compaction — sync before context is trimmed
    hooks["preCompact"]         = [{"command": f"{py} {hd}/pre_compact.py"}]

    # Stop — sync session knowledge on completion
    hooks["stop"]               = [{"command": f"{py} {hd}/stop.py"}]

    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(s, indent=2) + "\n")
    print(f"  ✓ Cursor: hooks registered (sessionStart, beforeSubmitPrompt, preToolUse, postToolUse, preCompact, stop)")


def install_codex_hooks(cfg: dict):
    """Wire hooks into ~/.codex/config.toml using Codex TOML hook format."""
    import re
    path = Path.home() / ".codex" / "config.toml"
    content = path.read_text() if path.exists() else ""

    py = sys.executable
    hd = str(HOOKS_DIR)

    new_hooks = (
        f'\n[[hooks.SessionStart]]\n'
        f'\n[[hooks.SessionStart.hooks]]\n'
        f'type = "command"\n'
        f'command = "{py} {hd}/session_start.py"\n'
        f'\n[[hooks.UserPromptSubmit]]\n'
        f'\n[[hooks.UserPromptSubmit.hooks]]\n'
        f'type = "command"\n'
        f'command = "{py} {hd}/user_prompt_submit.py"\n'
        f'\n[[hooks.PreToolUse]]\n'
        f'matcher = "Bash|WebFetch|Agent"\n'
        f'\n[[hooks.PreToolUse.hooks]]\n'
        f'type = "command"\n'
        f'command = "{py} {hd}/pre_tool_use.py"\n'
        f'\n[[hooks.PostToolUse]]\n'
        f'\n[[hooks.PostToolUse.hooks]]\n'
        f'type = "command"\n'
        f'command = "{py} {hd}/post_tool_use.py"\n'
        f'\n[[hooks.PreCompact]]\n'
        f'\n[[hooks.PreCompact.hooks]]\n'
        f'type = "command"\n'
        f'command = "{py} {hd}/pre_compact.py"\n'
        f'\n[[hooks.Stop]]\n'
        f'\n[[hooks.Stop.hooks]]\n'
        f'type = "command"\n'
        f'command = "{py} {hd}/stop.py"\n'
    )

    # Remove array-of-tables hook entries but preserve [hooks.state] section
    # Split off any [hooks.state] block before stripping [[hooks.*]] entries
    state_match = re.search(r'\n\[hooks\.state\].*', content, re.DOTALL)
    state_block = state_match.group(0) if state_match else ""
    if state_block:
        content = content[:state_match.start()]

    content = re.sub(
        r'\n\[\[hooks\.[^\]]+\]\].*?(?=\n\[|\Z)',
        '',
        content,
        flags=re.DOTALL,
    ).rstrip() + "\n"

    # Add [features] block to enable hooks if not present
    if "[features]" not in content:
        content += "\n[features]\nhooks = true\n"
    elif "hooks = true" not in content:
        content = re.sub(r'\[features\]', '[features]\nhooks = true', content, count=1)

    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content + new_hooks + state_block)
    print(f"  ✓ Codex: hooks registered (SessionStart, UserPromptSubmit, PreToolUse, PostToolUse, PreCompact, Stop)")


