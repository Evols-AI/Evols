def _write_context_file(path: Path, content: str, label: str):
    """Write content to path, merging if an Evols block already exists."""
    marker = "# Evols Team Intelligence"
    if path.exists():
        existing = path.read_text()
        if marker in existing:
            lines = existing.split("\n")
            start = next((i for i, l in enumerate(lines) if marker in l), None)
            if start is not None:
                end = next((i for i, l in enumerate(lines) if i > start and l.startswith("# ")), len(lines))
                existing = "\n".join(lines[:start] + lines[end:]).strip() + "\n\n"
            path.write_text(existing + content)
        else:
            path.write_text(existing.rstrip() + "\n\n" + content)
        print(f"  ✓ {label} updated")
    else:
        path.write_text(content)
        print(f"  ✓ {label} written")


