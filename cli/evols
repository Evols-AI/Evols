    save_config(cfg)
    print(f"\n✓ Logged in.")

    # Propagate new key to all already-installed agent configs
    agents = detect_agents()
    updated = []

    updaters = {
        "claude":      lambda: install_claude_mcp(cfg),
        "cursor":      lambda: install_cursor_mcp(cfg),
        "zed":         lambda: install_zed_mcp(cfg),
        "codex":       lambda: install_codex_mcp(cfg),
