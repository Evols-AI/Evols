def install_copilot_mcp(cfg: dict):
    """Register evols MCP server in VSCode settings for GitHub Copilot.

    Copilot reads MCP servers from the `github.copilot.chat.mcp.servers` key
    in VSCode's user settings.json.
    """
    path = _copilot_mcp_settings_path()
    if path is None:
        print(f"  ✗ Copilot: could not determine VSCode settings path")
        return
    try:
        s = json.loads(path.read_text()) if path.exists() else {}
    except Exception:
        s = {}
    # Copilot MCP servers live under github.copilot.chat.mcp.servers (array of objects)
    mcp_servers = s.setdefault("github.copilot.chat.mcp.servers", [])
    # Remove existing evols entry if present
    mcp_servers = [srv for srv in mcp_servers if srv.get("name") != "evols"]
    mcp_servers.append({
        "name": "evols",
        "command": str(CLI_PATH),
        "args": ["mcp-server"],
        "env": {
            "EVOLS_API_URL": cfg.get("api_url", EVOLS_API_URL_DEFAULT),
            "EVOLS_API_KEY": cfg.get("api_key", ""),
            "EVOLS_PLAN": cfg.get("plan_type", "pro"),
        },
    })
    s["github.copilot.chat.mcp.servers"] = mcp_servers
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(s, indent=2) + "\n")
    print(f"  ✓ Copilot: MCP server registered (VSCode settings.json)")


