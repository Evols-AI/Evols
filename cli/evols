def install_codex_mcp(cfg: dict):
    """Write evols MCP server to ~/.codex/config.toml (the only file Codex reads)."""
    import re
    path = Path.home() / ".codex" / "config.toml"
    content = path.read_text() if path.exists() else ""

    api_url = cfg.get("api_url", EVOLS_API_URL_DEFAULT)
    api_key = cfg.get("api_key", "")
    plan   = cfg.get("plan_type", "pro")

    new_section = (
        f'\n[mcp_servers.evols]\n'
        f'command = "{CLI_PATH}"\n'
        f'args = ["mcp-server"]\n'
        f'[mcp_servers.evols.env]\n'
        f'EVOLS_API_URL = "{api_url}"\n'
        f'EVOLS_API_KEY = "{api_key}"\n'
        f'EVOLS_PLAN = "{plan}"\n'
    )

    # Remove all evols mcp_servers sections (parent and any sub-sections like .env)
    content = re.sub(
        r'\n\[mcp_servers\.evols[^\]]*\].*?(?=\n\[[^\[]|\Z)',
        '',
        content,
        flags=re.DOTALL,
    ).rstrip() + "\n"

    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content + new_section)
    print(f"  ✓ Codex: MCP server registered (config.toml)")


